# ---- Postgres ----
POSTGRES_USER=scheduler
POSTGRES_PASSWORD=scheduler_pw
POSTGRES_DB=job_scheduler
POSTGRES_PORT=5432

# Connection string used by all backend services.
# Inside docker-compose the host is "postgres"; for local dev use "localhost".
DATABASE_URL=postgres://scheduler:scheduler_pw@postgres:5432/job_scheduler

# ---- API ----
API_PORT=4000
JWT_SECRET=change-me-in-production-please
JWT_EXPIRES_IN=7d

# ---- Worker ----
WORKER_CONCURRENCY=5
POLL_INTERVAL_MS=1000
# Lease / visibility timeout: how long a claimed job is owned before it can be reclaimed.
LEASE_SECONDS=60
HEARTBEAT_INTERVAL_MS=5000

# ---- Scheduler ----
SCHEDULER_INTERVAL_MS=2000

# ---- Reaper ----
REAPER_INTERVAL_MS=5000
# A worker with no heartbeat for this long is declared dead and its jobs requeued.
HEARTBEAT_TIMEOUT_SECONDS=30

# ---- Frontend ----
WEB_PORT=5173
# Base URL the browser uses to reach the API.
VITE_API_URL=http://localhost:4000
